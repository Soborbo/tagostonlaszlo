---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Köszönjük" description="Üzenetét megkaptuk.">
  <section class="max-w-[800px] mx-auto px-5 py-12 text-center">
    <h1 class="text-3xl md:text-4xl font-bold mb-6">Köszönjük az üzenetet!</h1>
    <p class="text-text-light text-lg mb-8">
      Megkaptuk üzenetét, és hamarosan válaszolunk.
    </p>
    <a
      href="/"
      class="inline-block bg-accent hover:bg-accent-light text-white font-semibold px-8 py-3 rounded-[10px] text-[15px] transition-colors"
    >
      Vissza a főoldalra
    </a>
  </section>
</Layout>
